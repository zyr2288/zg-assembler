{
	"name": "zg-assembler",
	"displayName": "ZG Assembler",
	"author": {
		"name": "ZENG GE"
	},
	"preview": true,
	"description": "A simple assembler for 6502/65816",
	"version": "0.1.1",
	"engines": {
		"vscode": "^1.67.0"
	},
	"repository": {
		"url": "https://github.com/zyr2288/zg-assembler/"
	},
	"icon": "syntaxes/chip.png",
	"categories": [
		"Programming Languages",
		"Other"
	],
	"activationEvents": [
		"onLanguage:zg-assembly"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "zg-assembly.compliteThis",
				"title": "编译本文件"
			},
			{
				"command": "zg-assembly.compliteMain",
				"title": "编译入口文件"
			}
		],
		"languages": [
			{
				"id": "zg-assembly",
				"extensions": [
					".asm"
				],
				"icon": {
					"dark": "./syntaxes/chip.png",
					"light": "./syntaxes/chip.png"
				},
				"configuration": "./syntaxes/language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "zg-assembly",
				"scopeName": "source.asm.zg-assembly",
				"path": "./syntaxes/zg-assembly.json"
			}
		],
		"menus": {
			"editor/context": [
				{
					"when": "editorLangId == zg-assembly",
					"command": "zg-assembly.compliteThis",
					"group": "z_command"
				},
				{
					"when": "editorLangId == zg-assembly",
					"command": "zg-assembly.compliteMain",
					"group": "z_command"
				}
			]
		},
		"configurationDefaults": {
			"[zg-assembly]": {
				"editor.wordBasedSuggestions": false,
				"editor.tabSize": 8
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/vscode": "^1.67.0",
		"@types/glob": "^7.2.0",
		"@types/mocha": "^9.1.0",
		"@types/node": "14.x",
		"@typescript-eslint/eslint-plugin": "^5.16.0",
		"@typescript-eslint/parser": "^5.16.0",
		"eslint": "^8.11.0",
		"glob": "^7.2.0",
		"mocha": "^9.2.2",
		"typescript": "^4.5.5",
		"@vscode/test-electron": "^2.1.3"
	}
}